# Optional: which agent backend handles each user turn.
#   anthropic   -> direct streaming calls to api.anthropic.com (needs ANTHROPIC_API_KEY,
#                  bills against API credits, uses our scoped tool surface).
#   claude-cli  -> shells out to the local `claude` CLI (uses your Claude Code subscription,
#                  uses Claude Code's built-in tools).
# If unset: auto-detected. Prefers `anthropic` when ANTHROPIC_API_KEY is set,
# falls back to `claude-cli` when only the CLI is available.
# AIDA_CHAT_BACKEND=claude-cli

# Required when backend=anthropic. Ignored when backend=claude-cli (in fact
# stripped from the subprocess env so `claude` falls back to subscription auth).
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model for the anthropic backend. Defaults to claude-sonnet-4-6.
# Ignored by claude-cli (the CLI picks its own model from your Claude Code config).
# AIDA_CHAT_MODEL=claude-sonnet-4-6

# Optional: explicit repo root to scope the agent's file/grep tools to.
# Defaults to the process's current working directory.
# AIDA_CHAT_REPO_ROOT=/home/you/code/your-project
